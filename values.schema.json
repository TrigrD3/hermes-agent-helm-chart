{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "strategy": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["Recreate", "RollingUpdate"]
        }
      }
    },
    "bootstrap": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "overwrite": {
          "type": "boolean"
        },
        "existingConfigMap": {
          "type": "string"
        }
      }
    },
    "apiServer": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "host": {
          "type": "string",
          "minLength": 1
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "corsOrigins": {
          "type": "string"
        },
        "modelName": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "webhook": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "telegramWebhook": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "url": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "secrets": {
      "type": "object",
      "properties": {
        "existingSecret": {
          "type": "string"
        },
        "API_SERVER_KEY": {
          "type": "string"
        },
        "TELEGRAM_BOT_TOKEN": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "persistence": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "existingClaim": {
          "type": "string"
        },
        "mountPath": {
          "type": "string",
          "minLength": 1
        },
        "accessMode": {
          "type": "string",
          "enum": ["ReadWriteOnce", "ReadOnlyMany", "ReadWriteMany", "ReadWriteOncePod"]
        },
        "size": {
          "type": "string",
          "minLength": 1
        },
        "storageClass": {
          "type": "string"
        }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "sessionAffinity": {
          "type": "string",
          "enum": ["None", "ClientIP"]
        },
        "externalTrafficPolicy": {
          "type": "string",
          "enum": ["", "Cluster", "Local"]
        },
        "internalTrafficPolicy": {
          "type": "string",
          "enum": ["", "Cluster", "Local"]
        },
        "loadBalancerSourceRanges": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ports": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["port"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "port": {
                "type": "integer",
                "minimum": 1,
                "maximum": 65535
              },
              "targetPort": {
                "anyOf": [
                  {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 65535
                  },
                  {
                    "type": "string",
                    "minLength": 1
                  }
                ]
              },
              "containerPort": {
                "type": "integer",
                "minimum": 1,
                "maximum": 65535
              },
              "protocol": {
                "type": "string",
                "enum": ["TCP", "UDP", "SCTP"]
              },
              "appProtocol": {
                "type": "string",
                "minLength": 1
              },
              "nodePort": {
                "type": "integer",
                "minimum": 30000,
                "maximum": 32767
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "className": {
          "type": "string"
        },
        "servicePortNumber": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "virtualService": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "gateways": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "hosts": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "timeout": {
          "type": "string",
          "minLength": 1
        },
        "servicePortNumber": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 65535
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "persistence": {
            "properties": {
              "enabled": {
                "const": true
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "replicaCount": {
            "maximum": 1
          },
          "strategy": {
            "properties": {
              "type": {
                "const": "Recreate"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "apiServer": {
            "properties": {
              "enabled": {
                "const": true
              }
            }
          }
        }
      },
      "then": {
        "anyOf": [
          {
            "properties": {
              "secrets": {
                "properties": {
                  "existingSecret": {
                    "minLength": 1
                  }
                }
              }
            }
          },
          {
            "properties": {
              "secrets": {
                "properties": {
                  "API_SERVER_KEY": {
                    "minLength": 1
                  }
                }
              }
            }
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "telegramWebhook": {
            "properties": {
              "enabled": {
                "const": true
              }
            }
          }
        }
      },
      "then": {
        "allOf": [
          {
            "properties": {
              "telegramWebhook": {
                "properties": {
                  "url": {
                    "minLength": 1
                  }
                }
              }
            }
          },
          {
            "anyOf": [
              {
                "properties": {
                  "secrets": {
                    "properties": {
                      "existingSecret": {
                        "minLength": 1
                      }
                    }
                  }
                }
              },
              {
                "properties": {
                  "secrets": {
                    "properties": {
                      "TELEGRAM_BOT_TOKEN": {
                        "minLength": 1
                      }
                    }
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "service": {
            "properties": {
              "enabled": {
                "const": true
              }
            }
          }
        }
      },
      "then": {
        "anyOf": [
          {
            "properties": {
              "service": {
                "properties": {
                  "ports": {
                    "minItems": 1
                  }
                }
              }
            }
          },
          {
            "properties": {
              "apiServer": {
                "properties": {
                  "enabled": {
                    "const": true
                  }
                }
              }
            }
          },
          {
            "properties": {
              "webhook": {
                "properties": {
                  "enabled": {
                    "const": true
                  }
                }
              }
            }
          },
          {
            "properties": {
              "telegramWebhook": {
                "properties": {
                  "enabled": {
                    "const": true
                  }
                }
              }
            }
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "ingress": {
            "properties": {
              "enabled": {
                "const": true
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "service": {
            "properties": {
              "enabled": {
                "const": true
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "virtualService": {
            "properties": {
              "enabled": {
                "const": true
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "service": {
            "properties": {
              "enabled": {
                "const": true
              }
            }
          },
          "virtualService": {
            "properties": {
              "gateways": {
                "minItems": 1
              },
              "hosts": {
                "minItems": 1
              }
            }
          }
        }
      }
    }
  ]
}
